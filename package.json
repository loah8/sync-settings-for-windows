{
	"name": "sync-settings-for-windows",
	"version": "0.1.0",
	"description": "Share Obsidian settings across vaults via profile-based symlinks.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"settings",
		"profile",
		"symlink"
	],
	"author": "KB",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.2.4",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3"
	}
}
